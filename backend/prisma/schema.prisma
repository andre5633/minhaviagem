generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  googleId  String   @unique @map("google_id")
  name      String
  email     String   @unique
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  lastLoginAt DateTime? @map("last_login_at")
  trips     Trip[]
  globalChecklists GlobalChecklist[]
  categories Category[]
  whatsappLink WhatsAppLink?
  waMessages WaMessage[]
  aiSettings AiSettings?
  aiUsage    AiUsage[]

  @@map("users")
}

model Trip {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  title       String
  destination String
  startDate   DateTime  @map("start_date") @db.Date
  endDate     DateTime  @map("end_date") @db.Date
  totalBudget Decimal   @map("total_budget") @db.Decimal(12, 2)
  cover       String
  coverImage  String?   @map("cover_image")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses    Expense[]
  checklists  Checklist[]

  @@map("trips")
}

model Expense {
  id          String   @id @default(uuid())
  tripId      String   @map("trip_id")
  category    String
  description String
  amount      Decimal  @db.Decimal(12, 2)
  expenseDate DateTime @map("expense_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model Checklist {
  id        String          @id @default(uuid())
  tripId    String          @map("trip_id")
  title     String
  isDefault Boolean         @default(false) @map("is_default")
  hidden    Boolean         @default(false)
  position  Int             @default(0)
  createdAt DateTime        @default(now()) @map("created_at")
  trip      Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tasks     ChecklistTask[]

  @@index([tripId])
  @@map("checklists")
}

model ChecklistTask {
  id          String    @id @default(uuid())
  checklistId String    @map("checklist_id")
  text        String
  responsible String?
  done        Boolean   @default(false)
  isDefault   Boolean   @default(false) @map("is_default")
  position    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
  @@map("checklist_tasks")
}

// Modelos globais (por usuário) — editados em Perfil > Meu Checklist.
// Toda nova viagem nasce com uma CÓPIA das listas globais habilitadas (enabled).
model GlobalChecklist {
  id        String                @id @default(uuid())
  userId    String                @map("user_id")
  title     String
  isDefault Boolean               @default(false) @map("is_default")
  enabled   Boolean               @default(true)
  position  Int                   @default(0)
  createdAt DateTime              @default(now()) @map("created_at")
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     GlobalChecklistItem[]

  @@index([userId])
  @@map("global_checklists")
}

model GlobalChecklistItem {
  id          String          @id @default(uuid())
  checklistId String          @map("global_checklist_id")
  text        String
  responsible String?
  position    Int             @default(0)
  createdAt   DateTime        @default(now()) @map("created_at")
  checklist   GlobalChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
  @@map("global_checklist_items")
}

// Categorias de despesa (por usuário). "key" é estável (referência das despesas);
// nome/ícone/cor são editáveis em Perfil > Minhas Categorias.
model Category {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  key       String
  name      String
  icon      String
  color     String
  isDefault Boolean  @default(false) @map("is_default")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("categories")
}

// Cache global das cotações (atualizado a partir de API externa).
model CurrencyRate {
  code      String   @id // USD, EUR, GBP, JPY, CHF
  name      String
  rate      Decimal  @db.Decimal(14, 4) // R$ por 1 unidade
  pctChange String?  @map("pct_change")
  fetchedAt DateTime @map("fetched_at")

  @@map("currency_rates")
}

// Vínculo entre um número de WhatsApp e um usuário do app.
// O pareamento é feito por CÓDIGO (o usuário envia o código no WhatsApp), não pelo
// número digitado — o wa_id que a Meta entrega nem sempre bate com o número informado
// (no Brasil ela costuma omitir o 9º dígito).
model WhatsAppLink {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  waId          String?   @unique @map("wa_id")
  phone         String? // apenas informativo, o que o usuário digitou
  code          String?
  codeExpiresAt DateTime? @map("code_expires_at")
  verifiedAt    DateTime? @map("verified_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@map("whatsapp_links")
}

// Histórico da conversa no WhatsApp (só texto). waMessageId é único: a Meta reenvia
// o mesmo evento quando não recebe 200 a tempo, e é isso que evita processar duas vezes.
model WaMessage {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  waMessageId String?  @unique @map("wa_message_id")
  role        String // 'user' | 'assistant'
  text        String
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("wa_messages")
}

// Permissão e teto de uso do agente, por cliente (editável no painel admin).
model AiSettings {
  userId            String   @id @map("user_id")
  enabled           Boolean  @default(true)
  monthlyMessageCap Int?     @map("monthly_message_cap")
  monthlyCostCapUsd Decimal? @map("monthly_cost_cap_usd") @db.Decimal(10, 2)
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_settings")
}

// Uma linha por resposta do agente — é a base do consumo/custo por cliente no admin.
model AiUsage {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  model           String
  inputTokens     Int      @map("input_tokens")
  outputTokens    Int      @map("output_tokens")
  cacheReadTokens Int      @default(0) @map("cache_read_tokens")
  costUsd         Decimal  @map("cost_usd") @db.Decimal(12, 6)
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ai_usage")
}
