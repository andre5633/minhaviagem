# ═══════════════════════════════════════════════════════════════════
#  MINHA VIAGEM — variáveis de ambiente
#  Copie para .env e preencha os valores. Nunca commite o .env real.
# ═══════════════════════════════════════════════════════════════════

# ─── PostgreSQL ─────────────────────────────────────────────────────
# Usadas pelo docker-compose.yml (dev) e pelo docker-compose.full.yml
# (deploy autossuficiente, que sobe o próprio Postgres).
POSTGRES_USER=mv
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=minhaviagem

# URL usada pelo backend (Prisma)
#  - Postgres no MESMO compose (docker-compose.full.yml / dev):
#      postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
#  - Postgres EXTERNO (docker-compose.prod.yml): URL completa do host externo
DATABASE_URL=postgresql://mv:troque_esta_senha@db:5432/minhaviagem

# ─── Google OAuth ───────────────────────────────────────────────────
# Crie em: https://console.cloud.google.com → APIs & Services → Credentials
# Tipo: OAuth 2.0 Client ID → Web application
#  - Authorized JavaScript origins:  https://seudominio.com
#  - Authorized redirect URI:        https://seudominio.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://seudominio.com/auth/google/callback

# ─── JWT ────────────────────────────────────────────────────────────
# Gere uma string aleatória forte:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria_minimo_32_chars
JWT_EXPIRES_IN=7d

# ─── Cotações de moedas (card no painel) ────────────────────────────
# Opcional. Sem token usa o fallback keyless (open.er-api.com).
# Com token (AwesomeAPI) traz variação % do dia: https://awesomeapi.com.br
AWESOMEAPI_TOKEN=

# ─── Área administrativa (/admin e admin.seudominio) ────────────────
# Senha ÚNICA de acesso ao painel admin (sem login de usuário).
# Use uma senha longa e aleatória:  openssl rand -base64 18
ADMIN_PASSWORD=troque_por_uma_senha_admin_forte

# ─── Assistente no WhatsApp (agente de IA) ──────────────────────────
# Opcional: sem estas variáveis o app funciona normal, só sem o assistente.
#
# META / WhatsApp Cloud API — developers.facebook.com → seu app → WhatsApp
#   Callback URL a cadastrar lá:  https://seudominio.com/api/whatsapp/webhook
#   Verify token: o mesmo valor de WHATSAPP_VERIFY_TOKEN abaixo.
#   Assine o campo "messages" no webhook.
#   Gere o verify token com:  openssl rand -hex 24
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=          # Configurações do app → Básico → Chave Secreta
WHATSAPP_PHONE_NUMBER_ID=     # WhatsApp → Configuração da API → ID do número
WHATSAPP_TOKEN=               # token permanente (System User), não o temporário de 24h
WHATSAPP_DISPLAY_NUMBER=      # número visível ao usuário, ex.: +55 11 91234-5678

# ANTHROPIC (Claude) — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Tetos padrão por cliente/mês (o admin pode sobrescrever por cliente em /admin).
# 0 = sem limite.
AI_DEFAULT_MONTHLY_MESSAGE_CAP=300
AI_DEFAULT_MONTHLY_COST_CAP_USD=10

# ─── App ────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=https://seudominio.com
NODE_ENV=production

# Porta do host onde o frontend é publicado (o nginx do host faz proxy).
# Usada por docker-compose.full.yml / docker-compose.deploy.yml.
WEB_PORT=8080
