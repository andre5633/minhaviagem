# ═══════════════════════════════════════════════════════════════════
#  MINHA VIAGEM — variáveis de ambiente
#  Copie para .env e preencha os valores. Nunca commite o .env real.
# ═══════════════════════════════════════════════════════════════════

# ─── PostgreSQL ─────────────────────────────────────────────────────
# DEV  → docker-compose.yml sobe um container local com estas credenciais
# PROD → não sobe container; use a URL completa do seu postgres externo
POSTGRES_USER=mv
POSTGRES_PASSWORD=mv_secret
POSTGRES_DB=minhaviagem

# URL usada pelo backend (Prisma)
# DEV  → postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
# PROD → postgresql://user:senha@host-externo:5432/minhaviagem?sslmode=require
DATABASE_URL=postgresql://mv:mv_secret@db:5432/minhaviagem

# ─── Google OAuth ───────────────────────────────────────────────────
# Crie em: https://console.cloud.google.com → APIs & Services → Credentials
# Tipo: OAuth 2.0 Client ID → Web application
# DEV  → Authorized redirect URI: http://localhost:4000/auth/google/callback
# PROD → Authorized redirect URI: https://seudominio.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# DEV
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
# PROD → GOOGLE_CALLBACK_URL=https://seudominio.com/auth/google/callback

# ─── JWT ────────────────────────────────────────────────────────────
# Gere uma string aleatória forte:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria_minimo_32_chars
JWT_EXPIRES_IN=7d

# ─── App ────────────────────────────────────────────────────────────
PORT=4000
# DEV
FRONTEND_URL=http://localhost:3000
# PROD → FRONTEND_URL=https://seudominio.com
NODE_ENV=development
# PROD → NODE_ENV=production
